# HIC引导配置文件
# 此文件仅包含引导时需要的配置
# 详细配置请参考 platform.yaml

# ==================== 内核配置 ====================
kernel=\EFI\HIC\kernel.hic

# ==================== 命令行参数 ====================
cmdline=console=ttyS0,115200n8

# ==================== 引导选项 ====================
timeout=5
debug=0
default=0

# ==================== 系统特性 ====================
# ACPI支持（已由platform.yaml配置）
acpi=1

# ==================== 日志配置 ====================
# 日志级别：0-ERROR, 1-WARN, 2-INFO, 3-DEBUG
log_level=2

# ==================== 调试选项 ====================
# 是否启用详细调试输出
verbose=0

# 是否启用内存转储
crash_dump=0